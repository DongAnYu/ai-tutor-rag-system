        "!pip install -q llama-index==0.14.0 llama-index-vector-stores-chroma==0.5.3 llama-index-llms-google-genai==0.5.0 \\\n",
        "                chromadb==1.0.21 llama-index-llms-openai==0.5.6 jedi==0.19.2"
